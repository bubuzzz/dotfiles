;; LSP
(use-package eglot
  :ensure nil 
  :hook ((python-mode python-ts-mode) . eglot-ensure)
  :config
  (with-eval-after-load 'eglot
    (add-to-list 'eglot-server-programs
                 '((python-mode python-ts-mode)
                   . ("basedpyright-langserver" "--stdio"))))

  (with-eval-after-load 'evil
    (define-key evil-normal-state-map (kbd "g d") 'xref-find-definitions)
    (define-key evil-normal-state-map (kbd "g r") 'xref-find-references)
    (define-key evil-normal-state-map (kbd "K")   'eldoc) ; Show documentation
    (define-key evil-normal-state-map (kbd "C-c r") 'eglot-rename)
    (define-key evil-normal-state-map (kbd "C-c a") 'eglot-code-actions)))

(use-package pyvenv
  :ensure t
  :config
  (pyvenv-mode 1)
  
  (add-hook 'pyvenv-post-activate-hook 
            (lambda () 
              (when (bound-and-true-p eglot--managed-mode)
                (eglot-reconnect)))))

;; Status line
(defface my/mode-line-unsaved-face
  '((t :foreground "purple" :weight bold))
  "Face for unsaved file components in the mode-line."
  :group 'mode-line-faces)

(defun my/mode-line-file-info ()
  "Return the formatted path and filename with dynamic theme colors."
  (let* ((file-path (buffer-file-name))
         (is-modified (and file-path (buffer-modified-p)))
         (path-face (if is-modified 'my/mode-line-unsaved-face 'mode-line-inactive))
         (name-face (if is-modified 'my/mode-line-unsaved-face 'font-lock-keyword-face)))
    
    (if file-path
        (let ((dir (file-name-directory file-path))
              (name (file-name-nondirectory file-path)))
          (concat
           (propertize (abbreviate-file-name dir) 'face path-face)
           (propertize name 'face name-face)))
      (propertize "%b" 'face 'font-lock-string-face))))

(line-number-mode 1)
(column-number-mode 1)

(setq-default mode-line-format
  '((:eval
     (concat
      (propertize " [%b] " 'face 'font-lock-type-face)
      (my/mode-line-file-info)
      " "
      (propertize 
       (make-string (max 1 (- (window-total-width)
                              (length (buffer-name))
                              (length (or (buffer-file-name) ""))
                              25)) ? )
       'face 'mode-line)
      
      (propertize " Ln %l, Col %c " 'face 'mode-line-inactive)))))

